yarn-debug.log*
yarn-error.log*

# TypeScript / Vite build output
dist/
packages/*/dist/
examples/*/dist/

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*~

# Local dev tooling (not relevant to contributors)
.claude/

# Env files
.env
.env.local
.env.*.local

# npm pack output
*.tgz
